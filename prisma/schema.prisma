generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model BettingPlatform {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  bonusText    String?
  affiliateUrl String   @default("#")
  rating       Float    @default(0)
  pros         String   @default("[]")
  cons         String   @default("[]")
  sports       String   @default("[]")
  payments     String   @default("[]")
  minDeposit   String?
  payoutSpeed  String?
  license      String?
  isFeatured   Boolean  @default(false)
  rank         Int      @default(999)
  isActive     Boolean  @default(true)
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  category        String    @default("General")
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("SUPER_ADMIN")
  createdAt    DateTime @default(now())
}

model AutoBlogSettings {
  id              String    @id @default("singleton")
  enabled         Boolean   @default(false)
  publishTime     String    @default("09:00")
  useRotation     Boolean   @default(true)
  topicIndex      Int       @default(0)
  lastPublishedAt DateTime?
  updatedAt       DateTime  @updatedAt
}
