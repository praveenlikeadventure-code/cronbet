generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model BettingPlatform {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  bonusText    String?
  affiliateUrl String   @default("#")
  rating       Float    @default(0)
  pros         String   @default("[]")
  cons         String   @default("[]")
  sports       String   @default("[]")
  payments     String   @default("[]")
  minDeposit   String?
  payoutSpeed  String?
  license      String?
  isFeatured   Boolean  @default(false)
  rank         Int      @default(999)
  isActive     Boolean  @default(true)
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  category        String    @default("General")
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("SUPER_ADMIN")
  createdAt    DateTime @default(now())
}

model AutoBlogSettings {
  id              String    @id @default("singleton")
  enabled         Boolean   @default(false)
  publishTime     String    @default("09:00")
  useRotation     Boolean   @default(true)
  topicIndex      Int       @default(0)
  lastPublishedAt DateTime?
  updatedAt       DateTime  @updatedAt
}

// Blog affiliate widget ads
model BlogAd {
  id                String   @id @default(cuid())
  name              String
  platformId        String
  // JSON array of positions: HEADER, FOOTER, LEFT_SIDEBAR, RIGHT_SIDEBAR, IN_CONTENT, ALL
  positions         String   @default("[\"ALL\"]")
  badge             String?  // "Top Pick", "Editor's Choice", "Hot", "New"
  highlightPoints   String   @default("[]") // JSON array of 2 strings
  priority          Int      @default(0) // lower = shown first
  isActive          Boolean  @default(true)
  displayOnAllBlogs Boolean  @default(true)
  specificBlogIds   String   @default("[]") // JSON array of blog post IDs
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Click tracking for affiliate links + popup interactions
model AffiliateClick {
  id         String   @id @default(cuid())
  adId       String
  platformId String
  blogId     String?
  blogSlug   String?
  position   String
  popupType  String?  // SCROLL | EXIT_INTENT | TIME  (null = inline widget)
  action     String?  // claimed | dismissed | auto_closed  (null = inline click)
  createdAt  DateTime @default(now())
}

// Global popup settings (singleton)
model PopupSettings {
  id                 String   @id @default("singleton")
  scrollEnabled      Boolean  @default(true)
  exitEnabled        Boolean  @default(true)
  timeEnabled        Boolean  @default(true)
  scrollTriggerPct   Int      @default(50)
  timeTriggerSeconds Int      @default(60)
  maxExitPlatforms   Int      @default(3)
  // JSON array of platform IDs to show in popups (empty = top-rated auto)
  popupPlatformIds   String   @default("[]")
  displayOnAllBlogs  Boolean  @default(true)
  specificBlogIds    String   @default("[]")
  updatedAt          DateTime @updatedAt
}
